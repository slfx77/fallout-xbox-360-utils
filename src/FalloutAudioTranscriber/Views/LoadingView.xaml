<?xml version="1.0" encoding="utf-8"?>

<UserControl
  x:Class="FalloutAudioTranscriber.Views.LoadingView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid>
    <Grid.RowDefinitions>
      <RowDefinition Height="*" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <!-- Center content -->
    <StackPanel
      Grid.Row="0"
      HorizontalAlignment="Center"
      VerticalAlignment="Center"
      MaxWidth="600"
      Spacing="16">

      <!-- Header -->
      <TextBlock
        Text="Load a Fallout NV Build"
        FontSize="24"
        FontWeight="SemiBold"
        HorizontalAlignment="Center" />

      <TextBlock
        Text="Select the Data directory containing BSA archives and ESM files."
        TextWrapping="Wrap"
        HorizontalAlignment="Center"
        Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

      <!-- Folder path display -->
      <Grid ColumnSpacing="8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBox
          x:Name="FolderPathBox"
          Grid.Column="0"
          PlaceholderText="No folder selected"
          IsReadOnly="True" />

        <Button
          x:Name="BrowseButton"
          Grid.Column="1"
          Content="Browse..."
          Click="BrowseButton_Click"
          Style="{ThemeResource AccentButtonStyle}" />
      </Grid>

      <!-- ESM file override (optional) -->
      <Grid ColumnSpacing="8">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>

        <TextBlock
          Grid.Column="0"
          Text="ESM File"
          VerticalAlignment="Center"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          FontSize="12" />

        <TextBox
          x:Name="EsmPathBox"
          Grid.Column="1"
          PlaceholderText="(auto-detect from Data folder)"
          IsReadOnly="True"
          FontSize="12" />

        <Button
          x:Name="EsmBrowseButton"
          Grid.Column="2"
          Content="Browse..."
          Click="EsmBrowseButton_Click" />

        <Button
          x:Name="EsmClearButton"
          Grid.Column="3"
          Content="Clear"
          Click="EsmClearButton_Click"
          Visibility="Collapsed" />
      </Grid>

      <!-- Load button -->
      <Button
        x:Name="LoadButton"
        Content="Load Build"
        HorizontalAlignment="Center"
        IsEnabled="False"
        Click="LoadButton_Click"
        MinWidth="120" />

      <!-- Results summary -->
      <Border
        x:Name="ResultsPanel"
        Visibility="Collapsed"
        Style="{StaticResource CardBorderStyle}">

        <StackPanel Spacing="4">
          <TextBlock
            x:Name="ResultsHeader"
            FontWeight="SemiBold"
            FontSize="14" />
          <TextBlock
            x:Name="ResultsDetails"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            FontSize="12"
            TextWrapping="Wrap" />
        </StackPanel>
      </Border>

    </StackPanel>

    <!-- Progress bar anchored to bottom, space always reserved to prevent layout jump -->
    <ProgressBar
      x:Name="LoadProgressBar"
      Grid.Row="1"
      Minimum="0"
      Maximum="100"
      Value="0"
      Opacity="0"
      Margin="0,0,0,4" />
  </Grid>
</UserControl>
