<?xml version="1.0" encoding="utf-8"?>

<UserControl
  x:Class="FalloutAudioTranscriber.Controls.VoiceFileDetailPanel"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Border
    Style="{StaticResource CardBorderStyle}"
    Width="320">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="12">
        <!-- Header -->
        <TextBlock
          Text="Voice File Details"
          Style="{StaticResource SectionHeaderStyle}" />

        <!-- No selection state -->
        <TextBlock
          x:Name="NoSelectionText"
          Text="Select a voice file to view details"
          TextWrapping="Wrap"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

        <!-- Details (shown when a file is selected) -->
        <StackPanel
          x:Name="DetailsPanel"
          Visibility="Collapsed"
          Spacing="8">

          <!-- FormID -->
          <StackPanel Spacing="2">
            <TextBlock Text="FormID" Style="{StaticResource SecondaryTextStyle}" />
            <TextBlock
              x:Name="FormIdText"
              Style="{StaticResource MonoTextStyle}" />
          </StackPanel>

          <!-- Topic Editor ID -->
          <StackPanel Spacing="2">
            <TextBlock Text="Topic" Style="{StaticResource SecondaryTextStyle}" />
            <TextBlock
              x:Name="TopicText"
              TextWrapping="Wrap" />
          </StackPanel>

          <!-- Voice Type -->
          <StackPanel Spacing="2">
            <TextBlock Text="Voice Type" Style="{StaticResource SecondaryTextStyle}" />
            <TextBlock
              x:Name="VoiceTypeText"
              TextWrapping="Wrap" />
          </StackPanel>

          <!-- Speaker -->
          <StackPanel
            x:Name="SpeakerPanel"
            Spacing="2"
            Visibility="Collapsed">
            <TextBlock Text="Speaker" Style="{StaticResource SecondaryTextStyle}" />
            <TextBlock
              x:Name="SpeakerText"
              TextWrapping="Wrap" />
          </StackPanel>

          <!-- Quest -->
          <StackPanel
            x:Name="QuestPanel"
            Spacing="2"
            Visibility="Collapsed">
            <TextBlock Text="Quest" Style="{StaticResource SecondaryTextStyle}" />
            <TextBlock
              x:Name="QuestText"
              TextWrapping="Wrap" />
          </StackPanel>

          <!-- Subtitle text -->
          <StackPanel Spacing="2">
            <TextBlock Text="Subtitle" Style="{StaticResource SecondaryTextStyle}" />
            <Border
              Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
              CornerRadius="4"
              Padding="8"
              MinHeight="60">
              <TextBlock
                x:Name="SubtitleText"
                TextWrapping="Wrap"
                FontStyle="Italic"
                Text="(no subtitle in ESM)" />
            </Border>
          </StackPanel>

          <!-- BSA path -->
          <StackPanel Spacing="2">
            <TextBlock Text="BSA Path" Style="{StaticResource SecondaryTextStyle}" />
            <TextBlock
              x:Name="BsaPathText"
              Style="{StaticResource MonoTextStyle}"
              TextWrapping="Wrap"
              FontSize="11"
              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
          </StackPanel>

          <!-- Transcription controls (shown for non-ESM entries) -->
          <StackPanel
            x:Name="TranscriptionPanel"
            Visibility="Collapsed"
            Spacing="8">

            <Border
              Background="{ThemeResource DividerStrokeColorDefaultBrush}"
              Height="1"
              Margin="0,4" />

            <!-- Status -->
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock Text="Status" Style="{StaticResource SecondaryTextStyle}"
                         VerticalAlignment="Center" />
              <TextBlock
                x:Name="TranscriptionStatusText"
                FontWeight="SemiBold"
                VerticalAlignment="Center" />
            </StackPanel>

            <!-- Whisper progress -->
            <StackPanel
              x:Name="WhisperProgressPanel"
              Visibility="Collapsed"
              Spacing="4">
              <TextBlock
                x:Name="WhisperStatusText"
                Text="Transcribing..."
                Style="{StaticResource SecondaryTextStyle}" />
              <ProgressBar
                x:Name="WhisperProgressBar"
                IsIndeterminate="True" />
            </StackPanel>

            <!-- Editable transcription text -->
            <TextBox
              x:Name="TranscriptionTextBox"
              AcceptsReturn="True"
              TextWrapping="Wrap"
              MinHeight="80"
              MaxHeight="200"
              PlaceholderText="Transcription text..."
              IsEnabled="False" />

            <!-- Action buttons -->
            <StackPanel
              Orientation="Horizontal"
              Spacing="8"
              HorizontalAlignment="Right">
              <Button
                x:Name="TranscribeButton"
                Content="Transcribe"
                Click="Transcribe_Click"
                IsEnabled="False" />
              <Button
                x:Name="ApproveButton"
                Content="Approve"
                Style="{ThemeResource AccentButtonStyle}"
                Click="Approve_Click"
                IsEnabled="False" />
            </StackPanel>

            <TextBlock
              Text="Ctrl+Enter = Approve"
              Style="{StaticResource SecondaryTextStyle}" />
          </StackPanel>
        </StackPanel>
      </StackPanel>
    </ScrollViewer>
  </Border>
</UserControl>
