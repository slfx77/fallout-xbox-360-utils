<?xml version="1.0" encoding="utf-8"?>

<UserControl
  x:Class="FalloutAudioTranscriber.Controls.AudioPlayerControl"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Grid
    Height="48"
    Padding="8,4">

    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="Auto" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Play/Pause/Stop buttons -->
    <StackPanel
      Grid.Column="0"
      Orientation="Horizontal"
      Spacing="4"
      VerticalAlignment="Center">

      <Button
        x:Name="PlayPauseButton"
        Width="36" Height="36"
        Padding="0"
        Click="PlayPause_Click"
        ToolTipService.ToolTip="Play/Pause"
        Background="Transparent"
        BorderBrush="Transparent">
        <FontIcon
          x:Name="PlayPauseIcon"
          Glyph="&#xE768;"
          FontSize="16" />
      </Button>

      <Button
        x:Name="StopButton"
        Width="36" Height="36"
        Padding="0"
        Click="Stop_Click"
        ToolTipService.ToolTip="Stop"
        Background="Transparent"
        BorderBrush="Transparent">
        <FontIcon Glyph="&#xE71A;" FontSize="14" />
      </Button>
    </StackPanel>

    <!-- Seek slider and time -->
    <Grid
      Grid.Column="1"
      Margin="8,0"
      VerticalAlignment="Center">

      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="Auto" />
      </Grid.RowDefinitions>

      <Slider
        x:Name="SeekSlider"
        Grid.Row="0"
        Minimum="0"
        Maximum="100"
        Value="0"
        IsEnabled="False"
        GettingFocus="SeekSlider_GettingFocus"
        LosingFocus="SeekSlider_LosingFocus"
        ValueChanged="SeekSlider_ValueChanged" />

      <Grid Grid.Row="1" Margin="0,-4,0,0">
        <TextBlock
          x:Name="PositionText"
          Text="0:00"
          FontSize="11"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          HorizontalAlignment="Left" />
        <TextBlock
          x:Name="DurationText"
          Text="0:00"
          FontSize="11"
          Foreground="{ThemeResource TextFillColorSecondaryBrush}"
          HorizontalAlignment="Right" />
      </Grid>
    </Grid>
  </Grid>
</UserControl>
