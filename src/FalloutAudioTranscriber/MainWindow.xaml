<?xml version="1.0" encoding="utf-8"?>

<Window
  x:Class="FalloutAudioTranscriber.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:views="using:FalloutAudioTranscriber.Views"
  Title="Fallout Audio Transcriber">

  <Grid>
    <NavigationView
      x:Name="NavView"
      Background="Transparent"
      IsBackButtonVisible="Collapsed"
      IsPaneToggleButtonVisible="True"
      IsSettingsVisible="False"
      IsTitleBarAutoPaddingEnabled="False"
      OpenPaneLength="200"
      PaneDisplayMode="LeftCompact"
      SelectionChanged="NavView_SelectionChanged">

      <NavigationView.MenuItems>
        <!-- Loading / Folder Picker -->
        <NavigationViewItem
          x:Name="NavLoading"
          Content="Load Build"
          IsSelected="True"
          Tag="Loading">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xED25;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <!-- Playlist / Browse -->
        <NavigationViewItem
          x:Name="NavPlaylist"
          Content="Voice Files"
          Tag="Playlist"
          IsEnabled="False">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE8D6;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

      </NavigationView.MenuItems>

      <!-- Main content area -->
      <Grid Background="Transparent">
        <Grid.RowDefinitions>
          <RowDefinition Height="32" />
          <RowDefinition Height="*" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border
          Grid.Row="1"
          Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
          CornerRadius="8,0,0,8">
          <Grid>
            <views:LoadingView
              x:Name="LoadingViewContent"
              Visibility="Visible" />
            <views:PlaylistView
              x:Name="PlaylistViewContent"
              Visibility="Collapsed" />
          </Grid>
        </Border>

        <!-- Status bar -->
        <Grid
          Grid.Row="2"
          Height="24"
          Padding="15,0,16,0"
          Background="Transparent">
          <TextBlock
            x:Name="StatusTextBlock"
            VerticalAlignment="Center"
            FontSize="12"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="" />
        </Grid>
      </Grid>
    </NavigationView>

    <!-- Title bar — rendered AFTER NavigationView so it's visible over the
         transparent 32px spacer row. Margin shifts via IsPaneOpen property
         callback (fires before animation) so title moves out of the way
         before the pane starts expanding. -->
    <Grid
      x:Name="AppTitleBar"
      Height="32"
      Margin="48,0,0,0"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Top"
      Background="Transparent">
      <StackPanel
        Orientation="Horizontal"
        VerticalAlignment="Center">
        <Image
          Width="16"
          Height="16"
          Margin="8,1,8,0"
          VerticalAlignment="Center"
          Source="ms-appx:///Assets/AppIcon.png" />
        <TextBlock
          x:Name="AppTitleText"
          Text="Fallout Audio Transcriber"
          VerticalAlignment="Center"
          FontSize="12" />
      </StackPanel>
    </Grid>
  </Grid>
</Window>
