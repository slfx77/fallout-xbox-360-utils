root = true
# EditorConfig is awesome: https://EditorConfig.org

# top-most EditorConfig file

# All files
[*]
indent_style = space
indent_size = 4
end_of_line = crlf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

# Microsoft .NET properties
csharp_prefer_braces = true:none

# ReSharper properties
resharper_apply_on_completion = true
resharper_braces_redundant = true

# C# files
[*.cs]
indent_size = 4

# Suppress CA1305: Spectre.Console CLI output uses invariant formatting intentionally
dotnet_diagnostic.ca1305.severity = none

# Suppress CA1720: Domain-specific identifiers (UInt8, Int32, Float) are intentional ESM field type names
dotnet_diagnostic.ca1720.severity = none

# Suppress CA1711/S2344: [Flags] enums with "Flags" suffix are intentional
dotnet_diagnostic.CA1711.severity = none
dotnet_diagnostic.S2344.severity = none

# Suppress LINQ suggestions: explicit loops are preferred in performance-sensitive code
dotnet_diagnostic.S3267.severity = none  # Loop should be simplified using LINQ
dotnet_diagnostic.S1155.severity = none  # Use .Any() instead of .Count()
dotnet_diagnostic.S6608.severity = none  # Use indexing instead of First()/Last()

# Code quality — these are inherent to binary format parsing (large switch statements,
# many record types, orchestrator classes referencing dozens of handlers).
# Kept as suggestions so they remain visible in IDE but don't pollute build output.
dotnet_diagnostic.S3776.severity = suggestion   # Cognitive complexity — irreducible in binary parsers
dotnet_diagnostic.CA1502.severity = suggestion  # Cyclomatic complexity — large switch statements
dotnet_diagnostic.S1200.severity = suggestion   # Class coupling — orchestrators legitimately reference many types
dotnet_diagnostic.IDE0060.severity = suggestion # Unused parameters — project uses _ discard convention

# Unused code detection (enable as warnings)
dotnet_diagnostic.ide0051.severity = warning # Unused private member
dotnet_diagnostic.ide0052.severity = warning # Unread private member
dotnet_diagnostic.ca1812.severity = warning # Internal class never instantiated
dotnet_diagnostic.ca1823.severity = warning # Unused private field

# XAML files
[*.xaml]
indent_size = 2

# ReSharper properties for WinUI 3 XAML
# Disable XAML inspections that don't understand WinUI 3
resharper_xaml_redundant_explicit_property_name_highlighting = none
resharper_xaml_obsolete_target_property_highlighting = none
resharper_unknown_xaml_namespace_highlighting = none
resharper_unresolved_tag_highlighting = none
resharper_unresolved_markup_extension_highlighting = none
resharper_xaml_unresolved_markup_extension_highlighting = none
resharper_xaml_style_class_not_found_highlighting = none
resharper_xaml_missing_xmlns_highlighting = none

# JSON files
[*.json]
indent_size = 2

# XML files
[*.xml]
indent_size = 2

# Project files
[*.{csproj,props,targets}]
indent_size = 2
