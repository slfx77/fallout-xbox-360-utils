<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
  x:Class="FalloutXbox360Utils.KeyboardShortcutsDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:FalloutXbox360Utils"
  Title="Keyboard shortcuts"
  CloseButtonText="Close"
  DefaultButton="Close"
  AutomationProperties.Name="Keyboard shortcuts"
  AutomationProperties.HeadingLevel="Level1">

  <ScrollViewer MaxHeight="520" Padding="0,4,0,0">
    <ListView
      x:Name="ShortcutsList"
      SelectionMode="None"
      IsItemClickEnabled="False"
      AutomationProperties.Name="Keyboard shortcuts list">
      <ListView.GroupStyle>
        <GroupStyle>
          <GroupStyle.HeaderTemplate>
            <DataTemplate>
              <TextBlock
                Text="{Binding Key}"
                AutomationProperties.HeadingLevel="Level2"
                Style="{StaticResource SubtitleTextBlockStyle}"
                Margin="0,12,0,4" />
            </DataTemplate>
          </GroupStyle.HeaderTemplate>
        </GroupStyle>
      </ListView.GroupStyle>
      <ListView.ItemTemplate>
        <DataTemplate x:DataType="local:KeyboardShortcut">
          <Grid Padding="0,4" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="160" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <Border
              Grid.Column="0"
              Background="{ThemeResource SubtleFillColorSecondaryBrush}"
              CornerRadius="4"
              Padding="8,2"
              HorizontalAlignment="Left">
              <TextBlock
                Text="{x:Bind Keys}"
                FontFamily="Consolas, Courier New"
                FontSize="13" />
            </Border>
            <TextBlock
              Grid.Column="1"
              Text="{x:Bind Action}"
              TextWrapping="Wrap"
              VerticalAlignment="Center" />
          </Grid>
        </DataTemplate>
      </ListView.ItemTemplate>
    </ListView>
  </ScrollViewer>
</ContentDialog>
