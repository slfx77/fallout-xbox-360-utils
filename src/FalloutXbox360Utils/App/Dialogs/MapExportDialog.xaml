<?xml version="1.0" encoding="utf-8"?>

<ContentDialog
  x:Class="FalloutXbox360Utils.MapExportDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="Export worldspace"
  PrimaryButtonText="Export..."
  CloseButtonText="Cancel"
  DefaultButton="Primary"
  AutomationProperties.Name="Export worldspace"
  AutomationProperties.HeadingLevel="Level1">

  <StackPanel Spacing="14" MinWidth="380">

    <StackPanel Spacing="4">
      <TextBlock Text="Resolution" Style="{StaticResource BodyStrongTextBlockStyle}"
                 AutomationProperties.HeadingLevel="Level2" />
      <TextBlock x:Name="WorldSizeText" FontSize="11"
                 Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
    </StackPanel>

    <StackPanel Orientation="Horizontal" Spacing="6">
      <Button Content="0.25x" Click="Preset_Click" Tag="0.25"
              AutomationProperties.Name="Quarter scale (8 pixels per cell)"
              ToolTipService.ToolTip="~8 px/cell" />
      <Button Content="0.5x" Click="Preset_Click" Tag="0.5"
              AutomationProperties.Name="Half scale (17 pixels per cell)"
              ToolTipService.ToolTip="~17 px/cell" />
      <Button Content="1x" Click="Preset_Click" Tag="1"
              AutomationProperties.Name="Native scale (33 pixels per cell)"
              ToolTipService.ToolTip="33 px/cell — native source resolution" />
      <Button Content="2x" Click="Preset_Click" Tag="2"
              AutomationProperties.Name="Double scale (66 pixels per cell)"
              ToolTipService.ToolTip="66 px/cell" />
      <Button Content="4x" Click="Preset_Click" Tag="4"
              AutomationProperties.Name="Quadruple scale (132 pixels per cell)"
              ToolTipService.ToolTip="132 px/cell" />
    </StackPanel>

    <Grid ColumnSpacing="8">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>
      <TextBlock Grid.Column="0" Text="Long edge:" VerticalAlignment="Center" />
      <NumberBox Grid.Column="1" x:Name="LongEdgeNumberBox"
                 Minimum="32" Maximum="32768" SmallChange="64" LargeChange="512"
                 SpinButtonPlacementMode="Inline"
                 ValueChanged="LongEdgeNumberBox_ValueChanged"
                 AutomationProperties.Name="Long edge in pixels" />
      <TextBlock Grid.Column="2" Text="px" VerticalAlignment="Center" />
    </Grid>

    <TextBlock x:Name="OutputSizeText" FontSize="11"
               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

    <StackPanel Spacing="4">
      <TextBlock Text="Include" Style="{StaticResource BodyStrongTextBlockStyle}"
                 AutomationProperties.HeadingLevel="Level2" />
      <CheckBox x:Name="MarkersCheckBox" Content="Map markers" />
      <CheckBox x:Name="NavMeshCheckBox" Content="Nav mesh" />
      <CheckBox x:Name="WaterCheckBox" Content="Water" />
    </StackPanel>

  </StackPanel>
</ContentDialog>
