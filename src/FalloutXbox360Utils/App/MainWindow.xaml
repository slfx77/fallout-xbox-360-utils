<?xml version="1.0" encoding="utf-8"?>

<Window
  x:Class="FalloutXbox360Utils.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:tabs="using:FalloutXbox360Utils"
  Title="Fallout Xbox 360 Utils">

  <Grid KeyboardAcceleratorPlacementMode="Hidden">
    <!--  Global keyboard shortcuts. F1 opens the cheat-sheet dialog, available anywhere.
          KeyboardAcceleratorPlacementMode="Hidden" on this root Grid suppresses WinUI's
          automatic "(F1)" hint from being injected into every descendant's tooltip — the
          cheat-sheet dialog covers discovery instead.  -->
    <Grid.KeyboardAccelerators>
      <KeyboardAccelerator Key="F1" Invoked="F1_ShortcutsDialog_Invoked" />
    </Grid.KeyboardAccelerators>

    <!--  Navigation View with hamburger menu - fills entire window  -->
    <NavigationView
      x:Name="NavView"
      Background="Transparent"
      IsBackButtonVisible="Collapsed"
      IsPaneToggleButtonVisible="True"
      IsSettingsVisible="False"
      IsTitleBarAutoPaddingEnabled="True"
      OpenPaneLength="200"
      PaneDisplayMode="LeftCompact"
      ItemInvoked="NavView_ItemInvoked"
      SelectionChanged="NavView_SelectionChanged">

      <!--  Make NavigationView content area transparent so Mica shows in title bar  -->
      <NavigationView.Resources>
      </NavigationView.Resources>

      <NavigationView.MenuItems>
        <NavigationViewItemHeader x:Uid="NavHeader_Explore" />

        <!--  Data Explorer  -->
        <NavigationViewItem
          x:Uid="Nav_SingleFile"
          IsSelected="True"
          Tag="SingleFile">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE8A5;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItemSeparator />

        <NavigationViewItemHeader x:Uid="NavHeader_Assets" />

        <!--  Archive Browser  -->
        <NavigationViewItem
          x:Uid="Nav_BsaExtractor"
          Tag="BsaExtractor">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE7B8;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <!--  Model Tools  -->
        <NavigationViewItem
          x:Uid="Nav_NifConverter"
          Tag="NifConverter">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xF158;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <!--  Texture Tools  -->
        <NavigationViewItem
          x:Uid="Nav_DdxConverter"
          Tag="DdxConverter">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xEB9F;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItemSeparator />

        <NavigationViewItemHeader x:Uid="NavHeader_Conversion" />

        <!--  Game Repacker  -->
        <NavigationViewItem
          x:Uid="Nav_Repacker"
          Tag="Repacker">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE777;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <!--  DMP to ESP Converter  -->
        <NavigationViewItem
          x:Uid="Nav_DmpToEspConverter"
          Tag="DmpToEspConverter">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE74E;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>

        <NavigationViewItemSeparator />

        <NavigationViewItemHeader x:Uid="NavHeader_MemoryDumps" />

        <!--  Batch Dump Analysis  -->
        <NavigationViewItem
          x:Uid="Nav_BatchMode"
          Tag="BatchMode">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE8B7;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.MenuItems>

      <NavigationView.FooterMenuItems>
        <NavigationViewItem
          x:Name="SettingsNavItem"
          Content="Settings"
          SelectsOnInvoked="False"
          Tag="Settings">
          <NavigationViewItem.Icon>
            <FontIcon Glyph="&#xE713;" />
          </NavigationViewItem.Icon>
        </NavigationViewItem>
      </NavigationView.FooterMenuItems>

      <!--  Main content area  -->
      <Grid Background="Transparent">
        <Grid.RowDefinitions>
          <RowDefinition Height="32" />
          <!--  Window controls area (title bar)  -->
          <RowDefinition Height="*" />
          <!--  Content  -->
          <RowDefinition Height="Auto" />
          <!--  Status bar  -->
        </Grid.RowDefinitions>

        <!--  Tab content with rounded corners at top-left and bottom-left  -->
        <Border
          Grid.Row="1"
          Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
          CornerRadius="8,0,0,8">
          <Grid VerticalAlignment="Stretch">
            <tabs:SingleFileTab
              x:Name="SingleFileTabContent"
              VerticalAlignment="Stretch"
              Visibility="Visible" />
            <tabs:BatchModeTab
              x:Name="BatchModeTabContent"
              VerticalAlignment="Stretch"
              Visibility="Collapsed" />
            <tabs:NifConverterTab
              x:Name="NifConverterTabContent"
              VerticalAlignment="Stretch"
              Visibility="Collapsed" />
            <tabs:DdxConverterTab
              x:Name="DdxConverterTabContent"
              VerticalAlignment="Stretch"
              Visibility="Collapsed" />
            <tabs:BsaExtractorTab
              x:Name="BsaExtractorTabContent"
              VerticalAlignment="Stretch"
              Visibility="Collapsed" />
            <tabs:RepackerTab
              x:Name="RepackerTabContent"
              VerticalAlignment="Stretch"
              Visibility="Collapsed" />
            <tabs:DmpToEspConverterTab
              x:Name="DmpToEspConverterTabContent"
              VerticalAlignment="Stretch"
              Visibility="Collapsed" />
          </Grid>
        </Border>

        <!--  Status bar (same transparent Mica as title bar)  -->
        <Grid
          Grid.Row="2"
          Height="24"
          Padding="15,0,16,0"
          Background="Transparent">
          <TextBlock
            x:Name="GlobalStatusTextBlock"
            VerticalAlignment="Center"
            FontSize="12"
            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
            Text="" />
        </Grid>
      </Grid>
    </NavigationView>

    <!--  Title bar drag region — rendered AFTER NavigationView so it sits above the
          NavView chrome and the back/forward buttons remain hit-testable. The transparent
          Background still allows the NavView visuals to show through, but clicks on this
          strip route to AppTitleBar's children (Back/Forward buttons) instead of being
          swallowed by the NavView header. Interactive controls are auto-excluded from
          the drag region by WinUI.  -->
    <Grid
      x:Name="AppTitleBar"
      Height="32"
      Margin="48,0,0,0"
      HorizontalAlignment="Stretch"
      VerticalAlignment="Top"
      Background="Transparent">
      <StackPanel
        Orientation="Horizontal"
        VerticalAlignment="Center">
        <Image
          Width="16"
          Height="16"
          Margin="8,1,8,0"
          VerticalAlignment="Center"
          Source="ms-appx:///Assets/AppIcon.png" />
        <TextBlock
          x:Name="AppTitleText"
          x:Uid="AppTitle"
          VerticalAlignment="Center"
          FontSize="12" />

        <!--  Nav buttons: inside the title bar so WinUI auto-excludes them from drag  -->
        <StackPanel
          x:Name="NavButtonPanel"
          Orientation="Horizontal"
          Margin="12,0,0,0"
          Visibility="Collapsed">
          <Button
            x:Name="NavBackButton"
            Width="28" Height="24" Padding="0"
            VerticalAlignment="Center"
            IsEnabled="False"
            Click="NavBack_Click"
            ToolTipService.ToolTip="Back (Alt+Left)"
            AutomationProperties.Name="Back"
            AutomationProperties.HelpText="Go back to the previously viewed tab (Alt+Left)"
            Background="Transparent" BorderBrush="Transparent">
            <FontIcon Glyph="&#xE72B;" FontSize="11" />
          </Button>
          <Button
            x:Name="NavForwardButton"
            Width="28" Height="24" Padding="0" Margin="2,0,0,0"
            VerticalAlignment="Center"
            IsEnabled="False"
            Click="NavForward_Click"
            ToolTipService.ToolTip="Forward (Alt+Right)"
            AutomationProperties.Name="Forward"
            AutomationProperties.HelpText="Go forward to the next tab in navigation history (Alt+Right)"
            Background="Transparent" BorderBrush="Transparent">
            <FontIcon Glyph="&#xE72A;" FontSize="11" />
          </Button>
        </StackPanel>
      </StackPanel>
    </Grid>
  </Grid>
</Window>
