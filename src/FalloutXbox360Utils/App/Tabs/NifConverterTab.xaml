<?xml version="1.0" encoding="utf-8"?>

<local:NifFileConverterBase
  x:Class="FalloutXbox360Utils.NifConverterTab"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:local="using:FalloutXbox360Utils"
  xmlns:toolkit="using:CommunityToolkit.WinUI.Controls">

  <Grid VerticalAlignment="Stretch">
    <!--  Settings drawer (shared across sub-tabs)  -->
    <Border
      x:Name="SettingsDrawer"
      Style="{StaticResource SettingsDrawerBorderStyle}">
      <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Spacing="16">
          <TextBlock Text="Settings" Style="{StaticResource SubtitleTextBlockStyle}" />
          <StackPanel Spacing="4">
            <TextBlock Text="Output" FontWeight="SemiBold" FontSize="13"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
            <CheckBox
              x:Name="PreserveStructureCheckBox"
              x:Uid="Checkbox_PreserveFolderStructure"
              MinWidth="0"
              IsChecked="True" />
            <CheckBox
              x:Name="OverwriteExistingCheckBox"
              x:Uid="Checkbox_OverwriteExisting"
              MinWidth="0" />
            <CheckBox
              x:Name="VerboseOutputCheckBox"
              x:Uid="Checkbox_VerboseOutput"
              MinWidth="0" />
          </StackPanel>
        </StackPanel>
      </ScrollViewer>
    </Border>

    <!--  Two sub-tabs: Batch Convert (bulk file conversion) + Viewer (single NIF browse/render)  -->
    <TabView
      x:Name="NifTabView"
      IsAddTabButtonVisible="False"
      CanDragTabs="False"
      CanReorderTabs="False"
      TabWidthMode="SizeToContent"
      VerticalAlignment="Stretch"
      HorizontalAlignment="Stretch"
      SelectionChanged="NifTabView_SelectionChanged">

      <!-- ==================== Batch Convert Tab ==================== -->
      <TabViewItem x:Name="NifBatchConvertTab" x:Uid="Tab_NifBatchConvert" IsClosable="False">
        <Grid Padding="16"
              VerticalAlignment="Stretch">
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
          </Grid.RowDefinitions>

          <!-- Header row: Title + Select buttons -->
          <Grid Grid.Row="0"
                Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Style="{StaticResource TabHeaderStackPanelStyle}">
              <TextBlock
                x:Uid="Header_NifConverter"
                AutomationProperties.HeadingLevel="Level1"
                Style="{StaticResource SubtitleTextBlockStyle}" />
              <TextBlock
                x:Uid="Subtitle_NifConverter"
                Style="{StaticResource TabSubtitleStyle}" />
            </StackPanel>
            <StackPanel
              Grid.Column="1"
              Style="{StaticResource SelectButtonsPanelStyle}">
              <Button
                x:Uid="Button_SelectAll"
                Click="SelectAllButton_Click" />
              <Button
                x:Uid="Button_SelectNone"
                Click="SelectNoneButton_Click" />
            </StackPanel>
          </Grid>

          <!-- Files List Card -->
          <Border
            Grid.Row="1"
            VerticalAlignment="Stretch"
            Style="{StaticResource CardBorderStyle}">
            <Grid VerticalAlignment="Stretch">
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
              </Grid.RowDefinitions>

              <!-- Column headers -->
              <Grid Grid.Row="0"
                    Style="{StaticResource ColumnHeaderGridStyle}">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="40" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="80" />
                  <ColumnDefinition Width="120" />
                  <ColumnDefinition Width="200" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           FontWeight="SemiBold"
                           Text="" />
                <Button
                  Grid.Column="1"
                  Style="{StaticResource SortableColumnHeaderButtonStyle}"
                  AutomationProperties.Name="Sort by file path"
                  Click="SortByFilePath_Click">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock x:Uid="Col_FilePath" FontWeight="SemiBold" />
                    <FontIcon x:Name="NifFilePathSortIcon"
                              Style="{StaticResource SortIconStyle}" />
                  </StackPanel>
                </Button>
                <Button
                  Grid.Column="2"
                  Style="{StaticResource SortableColumnHeaderButtonStyle}"
                  AutomationProperties.Name="Sort by size"
                  Click="SortBySize_Click">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock x:Uid="Col_Size" FontWeight="SemiBold" />
                    <FontIcon x:Name="NifSizeSortIcon"
                              Style="{StaticResource SortIconStyle}" />
                  </StackPanel>
                </Button>
                <Button
                  Grid.Column="3"
                  Style="{StaticResource SortableColumnHeaderButtonStyle}"
                  AutomationProperties.Name="Sort by format"
                  Click="SortByFormat_Click">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock x:Uid="Col_Format" FontWeight="SemiBold" />
                    <FontIcon x:Name="NifFormatSortIcon"
                              Style="{StaticResource SortIconStyle}" />
                  </StackPanel>
                </Button>
                <Button
                  Grid.Column="4"
                  Style="{StaticResource SortableColumnHeaderButtonStyle}"
                  AutomationProperties.Name="Sort by status"
                  Click="SortByStatus_Click">
                  <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock x:Uid="Col_Status" FontWeight="SemiBold" />
                    <FontIcon x:Name="NifStatusSortIcon"
                              Style="{StaticResource SortIconStyle}" />
                  </StackPanel>
                </Button>
              </Grid>

              <!-- Files ListView -->
              <ListView
                x:Name="NifFilesListView"
                Grid.Row="1"
                AutomationProperties.Name="Files to convert"
                Style="{StaticResource FileListViewStyle}">
                <ListView.ItemTemplate>
                  <DataTemplate x:DataType="local:NifFileEntry">
                    <Grid Style="{StaticResource ListItemRowGridStyle}">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="40" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="80" />
                        <ColumnDefinition Width="120" />
                        <ColumnDefinition Width="200" />
                      </Grid.ColumnDefinitions>
                      <CheckBox Grid.Column="0"
                                IsChecked="{x:Bind IsSelected, Mode=TwoWay}"
                                AutomationProperties.Name="{x:Bind RelativePath}" />
                      <TextBlock Grid.Column="1" VerticalAlignment="Center"
                                 Text="{x:Bind RelativePath}"
                                 TextTrimming="CharacterEllipsis"
                                 ToolTipService.ToolTip="{x:Bind FullPath}" />
                      <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                 Text="{x:Bind FileSizeDisplay}" />
                      <TextBlock Grid.Column="3" VerticalAlignment="Center"
                                 Foreground="{x:Bind FormatColor}"
                                 Text="{x:Bind FormatDescription}" />
                      <TextBlock Grid.Column="4" VerticalAlignment="Center"
                                 Foreground="{x:Bind StatusColor, Mode=OneWay}"
                                 Text="{x:Bind Status, Mode=OneWay}"
                                 TextTrimming="CharacterEllipsis"
                                 ToolTipService.ToolTip="{x:Bind Status, Mode=OneWay}" />
                    </Grid>
                  </DataTemplate>
                </ListView.ItemTemplate>
              </ListView>
            </Grid>
          </Border>

          <!-- Progress Bar -->
          <ProgressBar
            x:Name="NifConversionProgressBar"
            Grid.Row="2"
            Style="{StaticResource TabProgressBarStyle}" />

          <!-- Input/Output Section -->
          <Grid Grid.Row="3" Style="{StaticResource IoSectionGridStyle}">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock x:Name="NifInputDirectoryLabel"
                       x:Uid="Label_InputDirectory" Grid.Row="0" Grid.Column="0"
                       Style="{StaticResource IoLabelStyle}" />
            <TextBox x:Name="NifInputDirectoryTextBox" x:Uid="Input_NifInputDir"
                     Grid.Row="0" Grid.Column="1"
                     Style="{StaticResource IoTextBoxStyle}"
                     AutomationProperties.LabeledBy="{Binding ElementName=NifInputDirectoryLabel}"
                     TextChanged="InputDirectoryTextBox_TextChanged" />
            <Button x:Uid="Button_Browse" Grid.Row="0" Grid.Column="2"
                    AutomationProperties.Name="Browse for input directory"
                    Click="BrowseInputButton_Click" />
            <Button x:Name="NifConvertButton" x:Uid="Button_Convert"
                    Grid.Row="0" Grid.Column="3"
                    MinWidth="120" Margin="8,0,0,0"
                    Click="ConvertButton_Click" IsEnabled="False"
                    Style="{StaticResource AccentButtonStyle}" />

            <TextBlock x:Name="NifOutputDirectoryLabel"
                       x:Uid="Label_OutputDirectory" Grid.Row="1" Grid.Column="0"
                       Style="{StaticResource IoLabelStyle}" />
            <TextBox x:Name="NifOutputDirectoryTextBox" x:Uid="Input_ConvertOutputDir"
                     Grid.Row="1" Grid.Column="1"
                     Style="{StaticResource IoTextBoxStyle}"
                     AutomationProperties.LabeledBy="{Binding ElementName=NifOutputDirectoryLabel}"
                     TextChanged="OutputDirectoryTextBox_TextChanged" />
            <Button x:Uid="Button_Browse" Grid.Row="1" Grid.Column="2"
                    AutomationProperties.Name="Browse for output directory"
                    Click="BrowseOutputButton_Click" />
            <Button x:Name="NifCancelButton" x:Uid="Button_Cancel"
                    Grid.Row="1" Grid.Column="3"
                    Margin="8,0,0,0" HorizontalAlignment="Stretch"
                    Click="CancelButton_Click" IsEnabled="False" />
          </Grid>
        </Grid>
      </TabViewItem>

      <!-- ==================== Viewer Tab ==================== -->
      <TabViewItem x:Name="NifViewerTab" x:Uid="Tab_NifViewer" IsClosable="False">
        <Grid Padding="8" VerticalAlignment="Stretch">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280" MinWidth="200" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="*" MinWidth="300" />
            <ColumnDefinition Width="8" />
            <ColumnDefinition Width="300" MinWidth="240" />
          </Grid.ColumnDefinitions>

          <!-- Left: NIF File Browser -->
          <Grid Grid.Column="0">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Browse row -->
            <Grid Grid.Row="0" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox
                x:Name="NifViewerPathTextBox"
                PlaceholderText="Directory or BSA path..."
                Grid.Column="0"
                AutomationProperties.Name="NIF source path"
                AutomationProperties.HelpText="Path to a folder containing NIF files, or a BSA archive"
                FontSize="12" />
              <DropDownButton
                Grid.Column="1"
                Margin="4,0,0,0"
                AutomationProperties.Name="Open folder or BSA"
                ToolTipService.ToolTip="Browse for directory or BSA file">
                <DropDownButton.KeyboardAccelerators>
                  <KeyboardAccelerator Key="O" Modifiers="Control" />
                </DropDownButton.KeyboardAccelerators>
                <FontIcon Glyph="&#xE838;" FontSize="14" />
                <DropDownButton.Flyout>
                  <MenuFlyout Placement="BottomEdgeAlignedRight">
                    <MenuFlyoutItem Text="Open Folder..." Click="NifViewerBrowseFolder_Click">
                      <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE8B7;" />
                      </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                    <MenuFlyoutItem Text="Open BSA..." Click="NifViewerBrowseBsa_Click">
                      <MenuFlyoutItem.Icon>
                        <FontIcon Glyph="&#xE8E5;" />
                      </MenuFlyoutItem.Icon>
                    </MenuFlyoutItem>
                  </MenuFlyout>
                </DropDownButton.Flyout>
              </DropDownButton>
            </Grid>

            <!-- Texture BSA row -->
            <Grid Grid.Row="1" Margin="0,0,0,8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBox
                x:Name="NifViewerTextureBsaTextBox"
                PlaceholderText="Textures BSA (auto-detected)..."
                Grid.Column="0"
                AutomationProperties.Name="Textures BSA path"
                AutomationProperties.HelpText="Overrides the auto-detected textures BSA used when rendering NIFs"
                FontSize="12" />
              <Button
                Grid.Column="1"
                Margin="4,0,0,0"
                Click="NifViewerBrowseTextureBsa_Click"
                AutomationProperties.Name="Browse for textures BSA"
                ToolTipService.ToolTip="Browse for textures BSA">
                <FontIcon Glyph="&#xE8E5;" FontSize="14" />
              </Button>
            </Grid>

            <!-- Search box -->
            <TextBox
              x:Name="NifViewerSearchBox"
              Grid.Row="2"
              PlaceholderText="Filter files..."
              AutomationProperties.Name="Filter files"
              AutomationProperties.HelpText="Narrow the file tree to matching names"
              Margin="0,0,0,8"
              FontSize="12"
              TextChanged="NifViewerSearchBox_TextChanged" />

            <!-- File tree -->
            <Border Grid.Row="3"
                    Style="{StaticResource CardBorderStyle}">
              <TreeView
                x:Name="NifViewerTreeView"
                SelectionMode="Single"
                AutomationProperties.Name="NIF files in selected source"
                ItemInvoked="NifViewerTree_ItemInvoked">
                <TreeView.ItemTemplate>
                  <DataTemplate x:DataType="local:NifTreeViewItem">
                    <TreeViewItem
                      Content="{x:Bind DisplayName}"
                      ItemsSource="{x:Bind Children}"
                      IsExpanded="{x:Bind IsExpanded, Mode=TwoWay}" />
                  </DataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
            </Border>

            <!-- File count -->
            <TextBlock
              x:Name="NifViewerFileCount"
              Grid.Row="4"
              FontSize="11"
              Margin="0,4,0,0"
              Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
          </Grid>

          <!-- Splitter: tree ↔ preview -->
          <toolkit:GridSplitter Grid.Column="1" Style="{StaticResource ResizableSplitterStyle}" />

          <!-- Center: 3D Model Viewer -->
          <Grid Grid.Column="2">
            <Border Style="{StaticResource DarkCardBorderStyle}">
              <Grid>
                <WebView2
                  x:Name="NifModelViewer"
                  DefaultBackgroundColor="Transparent" />
                <ProgressRing
                  x:Name="NifModelLoadingRing"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Visibility="Collapsed" />
                <!-- Placeholder text when no model loaded -->
                <TextBlock
                  x:Name="NifViewerPlaceholderText"
                  Text="Select a NIF file to view"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                  FontSize="14" />
              </Grid>
            </Border>
          </Grid>

          <!-- Splitter: preview ↔ info/export -->
          <toolkit:GridSplitter Grid.Column="3" Style="{StaticResource ResizableSplitterStyle}" />

          <!-- Right: Info + Export Panel -->
          <ScrollViewer Grid.Column="4"
                        VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12" Padding="0,0,0,8">

              <!-- NIF Info -->
              <TextBlock Text="NIF Info"
                         AutomationProperties.HeadingLevel="Level2"
                         Style="{StaticResource SubtitleTextBlockStyle}" />
              <TextBlock
                x:Name="NifViewerInfoText"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap"
                Text="No file selected" />

              <!-- Block Types -->
              <TextBlock Text="Block Types"
                         AutomationProperties.HeadingLevel="Level3"
                         FontWeight="SemiBold" FontSize="13"
                         Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
              <TextBlock
                x:Name="NifViewerBlockTypesText"
                FontSize="11"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                TextWrapping="Wrap" />

              <!-- Export -->
              <TextBlock Text="Export"
                         AutomationProperties.HeadingLevel="Level3"
                         FontWeight="SemiBold" FontSize="13"
                         Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                         Margin="0,8,0,0" />
              <Button
                x:Name="NifViewerExportGlbButton"
                Content="Export as GLB..."
                HorizontalAlignment="Stretch"
                Click="NifViewerExportGlb_Click"
                IsEnabled="False">
                <Button.KeyboardAccelerators>
                  <KeyboardAccelerator Key="E" Modifiers="Control" />
                </Button.KeyboardAccelerators>
              </Button>

              <!-- Render PNG -->
              <TextBlock x:Name="NifViewerRenderSectionHeader"
                         Text="Render PNG (Software)"
                         AutomationProperties.HeadingLevel="Level3"
                         FontWeight="SemiBold" FontSize="13"
                         Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                         Margin="0,8,0,0" />
              <ComboBox
                x:Name="NifViewerPerspectiveComboBox"
                HorizontalAlignment="Stretch"
                AutomationProperties.Name="Render perspective"
                SelectedIndex="0">
                <ComboBoxItem Content="Front (single view)" Tag="front" />
                <ComboBoxItem Content="Isometric (4 views)" Tag="iso" />
                <ComboBoxItem Content="Side (4 views)" Tag="side" />
                <ComboBoxItem Content="Trimetric (4 views)" Tag="trimetric" />
              </ComboBox>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Name="NifViewerElevationSliderLabel"
                           Text="Elevation:" VerticalAlignment="Center" FontSize="12" />
                <Slider
                  x:Name="NifViewerElevationSlider"
                  Minimum="-90" Maximum="90" Value="0"
                  Width="140"
                  AutomationProperties.LabeledBy="{Binding ElementName=NifViewerElevationSliderLabel}"
                  ValueChanged="NifViewerElevationSlider_ValueChanged" />
                <TextBlock
                  x:Name="NifViewerElevationLabel"
                  Text="0"
                  AutomationProperties.Name="Current elevation angle"
                  AutomationProperties.LiveSetting="Polite"
                  VerticalAlignment="Center" FontSize="12" Width="30" />
              </StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Name="NifViewerSizeNumberBoxLabel"
                           Text="Resolution (px):" VerticalAlignment="Center" FontSize="12" />
                <NumberBox
                  x:Name="NifViewerSizeNumberBox"
                  Minimum="64" Maximum="4096"
                  Value="512"
                  SpinButtonPlacementMode="Compact"
                  SmallChange="64" LargeChange="256"
                  Width="120"
                  AutomationProperties.LabeledBy="{Binding ElementName=NifViewerSizeNumberBoxLabel}" />
              </StackPanel>
              <Button
                x:Name="NifViewerRenderPngButton"
                Content="Export as PNG..."
                HorizontalAlignment="Stretch"
                Click="NifViewerRenderPng_Click"
                IsEnabled="False">
                <Button.KeyboardAccelerators>
                  <KeyboardAccelerator Key="R" Modifiers="Control" />
                </Button.KeyboardAccelerators>
              </Button>
            </StackPanel>
          </ScrollViewer>
        </Grid>
      </TabViewItem>
    </TabView>
  </Grid>
</local:NifFileConverterBase>
